# ══════════════════════════════════════════════════════════
#  AI Voice Agent – Environment Variables
#  Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ── Business identity ─────────────────────────────────────
BUSINESS_NAME=Acme Plumbing
BUSINESS_PHONE=+1 (555) 123-4567
BUSINESS_EMAIL=hello@acmeplumbing.com
BUSINESS_WEBSITE=https://acmeplumbing.com
BUSINESS_HOURS=Monday to Friday, 8 AM to 6 PM Eastern Time
BUSINESS_TIMEZONE=America/New_York

# ── What the AI should know about your business ───────────
# List the services you offer (comma-separated)
BUSINESS_SERVICES=emergency plumbing, pipe repair, drain cleaning, water heater installation

# Any extra context the AI should know (FAQs, pricing notes, etc.)
BUSINESS_CONTEXT=We offer 24/7 emergency service for burst pipes and flooding. Standard call-out fee is $75. We service the greater Chicago area.

# ── AI voice agent settings ───────────────────────────────
AGENT_NAME=Aria
# Twilio voices: https://www.twilio.com/docs/voice/twiml/say/text-speech
AGENT_VOICE=Polly.Joanna-Neural
SPEECH_LANGUAGE=en-US

# Opening greeting (optional – a default is generated if omitted)
# BUSINESS_GREETING=Thank you for calling Acme Plumbing. We're currently unavailable.

# ── Escalation (optional) ─────────────────────────────────
# Transfer the call to a human when caller requests it
ESCALATION_PHONE=+15551234567
ESCALATION_MESSAGE=Let me connect you with our on-call technician.

# ── Lead capture ──────────────────────────────────────────
CAPTURE_LEADS=true
# Webhook URL to receive new lead data (Zapier, Make, your CRM, etc.)
# LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

# ── AI model ──────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini

# ── Security ──────────────────────────────────────────────
# Set to true in production to verify all requests come from Twilio
VALIDATE_TWILIO_SIGNATURE=false

# ── Server ────────────────────────────────────────────────
PORT=3000
