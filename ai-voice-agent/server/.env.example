# ---- Answerly voice agent server config ----
# Copy to ".env" and fill in. The server runs without these (scripted
# fallback + console summaries), but you need them to go live on a phone.

PORT=3000

# Public URL where this server is reachable (for Twilio webhooks).
# During local dev, use an ngrok/cloudflared tunnel, e.g. https://abc123.ngrok.io
PUBLIC_BASE_URL=

# --- OpenAI (the "brain") ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Twilio (the phone line) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Where lead summaries are texted when a call ends.
OWNER_PHONE_NUMBER=+1XXXXXXXXXX
