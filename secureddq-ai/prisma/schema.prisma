generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  SECURITY_MANAGER
  SECURITY_ANALYST
  SALES_ENGINEER
  VIEWER
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum QuestionnaireStatus {
  DRAFT
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  ARCHIVED
}

enum QuestionType {
  LONG_TEXT
  SHORT_TEXT
  MULTIPLE_CHOICE
  CHECKBOX
  YES_NO
  NUMBER
}

enum AnswerStatus {
  DRAFT
  EDITED
  APPROVED
  REJECTED
}

enum DocumentStatus {
  PROCESSING
  ACTIVE
  ARCHIVED
  FAILED
}

enum NotificationType {
  NEW_QUESTIONNAIRE
  REVIEW_REQUEST
  DEADLINE
  DOCUMENT_EXPIRING
  BILLING_ISSUE
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

model User {
  id              String                 @id @default(cuid())
  clerkUserId     String                 @unique
  email           String                 @unique
  firstName       String?
  lastName        String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  organizationMap OrganizationMembership[]
  comments        Comment[]
  answerVersions  AnswerVersion[]
  notifications   Notification[]
  apiKeys         ApiKey[]
  activityLogs    ActivityLog[]
}

model Organization {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  website               String?
  industry              String?
  profile               Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  memberships           OrganizationMembership[]
  projects              Project[]
  questionnaires        Questionnaire[]
  knowledgeDocuments    Document[]
  controls              ComplianceControl[]
  subscriptions         Subscription[]
  invoices              Invoice[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  activityLogs          ActivityLog[]
  aiUsageLogs           AiUsageLog[]
  settings              Setting[]
  apiKeys               ApiKey[]
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           UserRole
  invitedBy      String?
  invitedAt      DateTime?
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Project {
  id              String               @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  status          ProjectStatus        @default(DRAFT)
  dueDate         DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  questionnaires  Questionnaire[]
  comments        Comment[]
  activityLogs    ActivityLog[]
  knowledgeScopes KnowledgeScope[]
}

model Questionnaire {
  id               String              @id @default(cuid())
  organizationId   String
  projectId        String
  name             String
  sourceFile       String?
  status           QuestionnaireStatus @default(DRAFT)
  completionPct    Float               @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questions        Question[]
  activityLogs     ActivityLog[]
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model Question {
  id               String       @id @default(cuid())
  questionnaireId  String
  externalId       String?
  section          String?
  prompt           String
  type             QuestionType @default(LONG_TEXT)
  isRequired       Boolean      @default(true)
  options          Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  questionnaire    Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  answers          Answer[]

  @@index([questionnaireId, section])
}

model Answer {
  id             String       @id @default(cuid())
  questionId     String
  content        String?
  confidence     Float?
  status         AnswerStatus @default(DRAFT)
  citations      Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  question       Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  versions       AnswerVersion[]
  evidences      Evidence[]
  comments       Comment[]
}

model AnswerVersion {
  id         String   @id @default(cuid())
  answerId   String
  userId     String
  content    String
  source     String
  createdAt  DateTime @default(now())
  answer     Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id                String         @id @default(cuid())
  organizationId    String
  title             String
  fileKey           String         @unique
  fileName          String
  mimeType          String
  fileSizeBytes     Int
  checksum          String?
  status            DocumentStatus @default(PROCESSING)
  tags              String[]
  versionLabel      String?
  expiresAt         DateTime?
  metadata          Json?
  extractedText     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  archivedAt        DateTime?
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chunks            DocumentChunk[]
  evidences         Evidence[]
  controlMappings   ComplianceControlMapping[]
  historyEntries    DocumentHistory[]
  knowledgeScopes   KnowledgeScope[]

  @@index([organizationId, status])
}

model DocumentChunk {
  id              String   @id @default(cuid())
  documentId      String
  chunkIndex      Int
  content         String
  tokenCount      Int
  metadata        Json?
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
}

model Evidence {
  id          String   @id @default(cuid())
  answerId    String
  documentId  String
  chunkIds    String[]
  excerpt     String
  relevance   Float?
  createdAt   DateTime @default(now())
  answer      Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model ComplianceControl {
  id              String                     @id @default(cuid())
  organizationId  String
  framework       String
  code            String
  title           String
  description     String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  organization    Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mappings        ComplianceControlMapping[]

  @@unique([organizationId, framework, code])
}

model ComplianceControlMapping {
  id          String            @id @default(cuid())
  controlId   String
  documentId  String
  confidence  Float?
  createdAt   DateTime          @default(now())
  control     ComplianceControl @relation(fields: [controlId], references: [id], onDelete: Cascade)
  document    Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([controlId, documentId])
}

model Comment {
  id          String    @id @default(cuid())
  organizationId String
  projectId   String?
  answerId    String?
  userId      String
  content     String
  mentions    String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  answer      Answer?   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String    @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  createdAt      DateTime  @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                    String           @id @default(cuid())
  organizationId        String
  stripeCustomerId      String?
  stripeSubscriptionId  String?          @unique
  plan                  SubscriptionPlan @default(FREE)
  status                String
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String    @id @default(cuid())
  organizationId String
  stripeInvoiceId String?  @unique
  amountCents    Int
  currency       String    @default("usd")
  paidAt         DateTime?
  status         String
  hostedUrl      String?
  createdAt      DateTime  @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String              @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  channel        NotificationChannel
  subject        String
  body           String
  readAt         DateTime?
  createdAt      DateTime            @default(now())
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String?
  questionnaireId String?
  userId         String?
  eventName      String
  metadata       Json?
  createdAt      DateTime  @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  questionnaire  Questionnaire? @relation(fields: [questionnaireId], references: [id], onDelete: SetNull)
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  name           String
  keyHash        String
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  id             String    @id @default(cuid())
  organizationId String
  key            String
  value          Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
}

model AiUsageLog {
  id             String    @id @default(cuid())
  organizationId String
  model          String
  inputTokens    Int
  outputTokens   Int
  costUsd        Float?
  action         String
  createdAt      DateTime  @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model DocumentHistory {
  id          String    @id @default(cuid())
  documentId  String
  event       String
  note        String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model KnowledgeScope {
  id          String   @id @default(cuid())
  projectId   String
  documentId  String
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([projectId, documentId])
}
