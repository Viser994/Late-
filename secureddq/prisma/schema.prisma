// SecureDDQ AI — Prisma schema
// PostgreSQL + pgvector. Enable the extension once per database:
//   CREATE EXTENSION IF NOT EXISTS vector;
// The `Embedding.vector` column is created as `vector(1536)` via a migration
// (see prisma/migrations). Prisma models the column as Unsupported so the rest
// of the schema stays fully typed.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─────────────────────────────── Enums ───────────────────────────────

enum Role {
  OWNER
  ADMIN
  SECURITY_MANAGER
  SECURITY_ANALYST
  SALES_ENGINEER
  VIEWER
}

enum PlanTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  UNPAID
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum DocumentType {
  POLICY
  SOC_REPORT
  ISO_DOCUMENT
  ARCHITECTURE
  PENTEST_REPORT
  SECURITY_POLICY
  EVIDENCE
  OTHER
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum ProcessingStage {
  QUEUED
  EXTRACTING
  OCR
  CHUNKING
  EMBEDDING
  INDEXED
  ERROR
}

enum QuestionnaireStatus {
  DRAFT
  PROCESSING
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  EXPORTED
  ARCHIVED
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  YES_NO
  MULTIPLE_CHOICE
  CHECKBOX
  DATE
  NUMBER
  FILE
}

enum AnswerStatus {
  DRAFT
  GENERATED
  EDITED
  APPROVED
  REJECTED
  NEEDS_INFO
}

enum AnswerStyle {
  CONCISE
  DETAILED
  FORMAL
  TECHNICAL
}

enum Framework {
  SOC2
  ISO27001
  HIPAA
  GDPR
  PCI_DSS
  NIST_CSF
  NIST_80053
}

enum ControlStatus {
  NOT_STARTED
  IN_PROGRESS
  IMPLEMENTED
  NOT_APPLICABLE
}

enum NotificationType {
  QUESTIONNAIRE_ASSIGNED
  REVIEW_REQUESTED
  DEADLINE_APPROACHING
  DOCUMENT_EXPIRING
  SUBSCRIPTION_ISSUE
  MENTION
  SYSTEM
}

enum ExportFormat {
  XLSX
  DOCX
  PDF
  CSV
}

// ─────────────────────────────── Identity ───────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  hashedPassword   String?
  image            String?
  emailVerified    DateTime?
  mfaEnabled       Boolean   @default(false)
  mfaSecret        String?
  lastActiveAt     DateTime?
  isPlatformAdmin  Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  memberships   Membership[]
  accounts      OAuthAccount[]
  sessions      Session[]
  comments      Comment[]
  activityLogs  ActivityLog[]
  auditLogs     AuditLog[]
  notifications Notification[]
  assignedQuestions Question[] @relation("QuestionAssignee")
  authoredAnswers   Answer[]   @relation("AnswerAuthor")

  @@index([email])
}

model OAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  purpose    String   @default("email_verification")
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

// ─────────────────────────────── Organization ───────────────────────────────

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logoUrl       String?
  website       String?
  industry      String?
  employeeCount String?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships   Membership[]
  invitations   Invitation[]
  subscription  Subscription?
  invoices      Invoice[]
  documents     Document[]
  projects      Project[]
  questionnaires Questionnaire[]
  chats         ChatSession[]
  controls      ComplianceControl[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  aiUsage       AiUsageRecord[]
  settings      OrganizationSetting?

  @@index([slug])
}

model Membership {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           Role             @default(VIEWER)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           Role         @default(VIEWER)
  token          String       @unique
  invitedById    String?
  acceptedAt     DateTime?
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
}

model OrganizationSetting {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  defaultAnswerStyle   AnswerStyle  @default(DETAILED)
  autoGenerateAnswers  Boolean      @default(true)
  requireApproval      Boolean      @default(true)
  confidenceThreshold  Float        @default(0.7)
  ssoEnabled           Boolean      @default(false)
  enforceMfa           Boolean      @default(false)
  dataRetentionDays    Int          @default(365)
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────── Billing ───────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  plan                 PlanTier           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  seats                Int                @default(2)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Invoice {
  id               String       @id @default(cuid())
  organizationId   String
  stripeInvoiceId  String?      @unique
  number           String?
  amountDue        Int
  amountPaid       Int
  currency         String       @default("usd")
  status           String
  hostedInvoiceUrl String?
  pdfUrl           String?
  periodStart      DateTime?
  periodEnd        DateTime?
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ─────────────────────────────── Knowledge base ───────────────────────────────

model Document {
  id             String          @id @default(cuid())
  organizationId String
  title          String
  description    String?
  type           DocumentType    @default(OTHER)
  status         DocumentStatus  @default(UPLOADED)
  processingStage ProcessingStage @default(QUEUED)
  fileKey        String?
  fileUrl        String?
  mimeType       String?
  sizeBytes      Int             @default(0)
  version        Int             @default(1)
  parentId       String?
  contentHash    String?
  effectiveDate  DateTime?
  expiresAt      DateTime?
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Document?     @relation("DocumentVersions", fields: [parentId], references: [id])
  versions     Document[]    @relation("DocumentVersions")
  chunks       Chunk[]
  tags         DocumentTag[]
  evidence     Evidence[]

  @@index([organizationId])
  @@index([type])
  @@index([status])
}

model DocumentTag {
  id         String   @id @default(cuid())
  documentId String
  label      String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, label])
}

model Chunk {
  id          String     @id @default(cuid())
  documentId  String
  index       Int
  content     String
  tokenCount  Int        @default(0)
  page        Int?
  section     String?
  createdAt   DateTime   @default(now())
  document    Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding   Embedding?

  @@index([documentId])
}

// The vector column itself is added by a raw SQL migration:
//   ALTER TABLE "Embedding" ADD COLUMN "vector" vector(1536);
//   CREATE INDEX ON "Embedding" USING hnsw ("vector" vector_cosine_ops);
model Embedding {
  id        String                       @id @default(cuid())
  chunkId   String                       @unique
  model     String                       @default("text-embedding-3-small")
  vector    Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())
  chunk     Chunk                        @relation(fields: [chunkId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────── Projects & questionnaires ───────────────────────────────

model Project {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  questionnaires Questionnaire[]

  @@index([organizationId])
}

model Questionnaire {
  id             String              @id @default(cuid())
  organizationId String
  projectId      String?
  title          String
  description    String?
  status         QuestionnaireStatus @default(DRAFT)
  sourceFileKey  String?
  dueDate        DateTime?
  requesterName  String?
  requesterEmail String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id])
  sections     Section[]
  questions    Question[]
  exports      ExportJob[]

  @@index([organizationId])
  @@index([status])
}

model Section {
  id              String        @id @default(cuid())
  questionnaireId String
  title           String
  order           Int           @default(0)
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  questions       Question[]

  @@index([questionnaireId])
}

model Question {
  id              String        @id @default(cuid())
  questionnaireId String
  sectionId       String?
  order           Int           @default(0)
  prompt          String
  type            QuestionType  @default(LONG_TEXT)
  required        Boolean       @default(false)
  options         String[]      @default([])
  assigneeId      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  section       Section?      @relation(fields: [sectionId], references: [id])
  assignee      User?         @relation("QuestionAssignee", fields: [assigneeId], references: [id])
  answer        Answer?

  @@index([questionnaireId])
  @@index([sectionId])
}

model Answer {
  id              String       @id @default(cuid())
  questionId      String       @unique
  content         String       @default("")
  status          AnswerStatus @default(DRAFT)
  style           AnswerStyle  @default(DETAILED)
  confidence      Float?
  aiGenerated     Boolean      @default(false)
  authorId        String?
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  question  Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  author    User?           @relation("AnswerAuthor", fields: [authorId], references: [id])
  citations Citation[]
  comments  Comment[]
  revisions AnswerRevision[]

  @@index([status])
}

model AnswerRevision {
  id        String   @id @default(cuid())
  answerId  String
  content   String
  status    AnswerStatus
  editorId  String?
  createdAt DateTime @default(now())
  answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@index([answerId])
}

model Citation {
  id         String   @id @default(cuid())
  answerId   String
  chunkId    String?
  documentId String?
  quote      String
  relevance  Float    @default(0)
  answer     Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@index([answerId])
}

model Evidence {
  id         String   @id @default(cuid())
  controlId  String?
  documentId String?
  note       String?
  createdAt  DateTime @default(now())
  control    ComplianceControl? @relation(fields: [controlId], references: [id], onDelete: Cascade)
  document   Document?          @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([controlId])
}

// ─────────────────────────────── Compliance ───────────────────────────────

model ComplianceControl {
  id             String        @id @default(cuid())
  organizationId String
  framework      Framework
  code           String
  title          String
  description    String?
  status         ControlStatus @default(NOT_STARTED)
  ownerId        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  evidence       Evidence[]

  @@unique([organizationId, framework, code])
  @@index([framework])
}

// ─────────────────────────────── Collaboration ───────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  answerId  String
  authorId  String
  body      String
  mentions  String[] @default([])
  createdAt DateTime @default(now())
  answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([answerId])
}

// ─────────────────────────────── AI chat ───────────────────────────────

model ChatSession {
  id             String        @id @default(cuid())
  organizationId String
  title          String        @default("New conversation")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]

  @@index([organizationId])
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          String
  content       String
  citations     Json?
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
}

// ─────────────────────────────── Ops, audit & notifications ───────────────────────────────

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  prefix         String
  hashedKey      String
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AiUsageRecord {
  id             String       @id @default(cuid())
  organizationId String
  operation      String
  model          String
  promptTokens   Int          @default(0)
  completionTokens Int        @default(0)
  totalTokens    Int          @default(0)
  costCents      Int          @default(0)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String?
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdAt])
}

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String?
  verb           String
  summary        String
  targetType     String?
  targetId       String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdAt])
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  title          String
  body           String?
  link           String?
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ExportJob {
  id              String        @id @default(cuid())
  questionnaireId String
  format          ExportFormat
  status          String        @default("queued")
  fileUrl         String?
  createdAt       DateTime      @default(now())
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)

  @@index([questionnaireId])
}
