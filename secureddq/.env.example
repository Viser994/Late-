# ─────────────────────────────────────────────────────────────
# SecureDDQ AI — Environment configuration
# Copy to `.env` and fill in the values. All AI/Stripe/storage
# integrations gracefully degrade to safe local mocks when the
# corresponding keys are absent, so the app runs without them.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth — 32+ char secret used to sign session JWTs
AUTH_SECRET=change-me-to-a-long-random-string-min-32-chars

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Database — PostgreSQL with the pgvector extension enabled
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secureddq?schema=public

# OpenAI (RAG). When unset, the AI layer returns deterministic mock output.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Stripe billing (optional in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx

# File storage — S3-compatible (optional in dev; falls back to local disk)
S3_REGION=us-east-1
S3_BUCKET=secureddq-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# Email (optional; falls back to console transport)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=SecureDDQ AI <no-reply@secureddq.ai>
